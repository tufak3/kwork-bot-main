# === Groq API ===
# Один ключ (для совместимости)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Несколько ключей через запятую (рекомендуется для ротации)
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# === Claude API (опционально) ===
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# === OpenAI API (опционально) ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# === Telegram Bot ===
# Получить у @BotFather командой /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Окружение ===
NODE_ENV=production
PORT=3000

# === Только для Render — заполняется автоматически ===
# RENDER_EXTERNAL_URL=https://kwork-monitor.onrender.com
